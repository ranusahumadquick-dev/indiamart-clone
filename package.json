{
  "name": "indiamart",
  "version": "1.0.0",
  "description": "IndiaMart — B2B Marketplace Platform connecting buyers with verified suppliers across India",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "install:all": "cd backend && npm install && cd ../frontend && npm install"
  },
  "keywords": [
    "b2b",
    "marketplace",
    "indiamart",
    "ecommerce"
  ],
  "author": "IndiaMart Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemailer": "^8.0.7"
  },
  "dependencies": {
    "playwright": "^1.60.0"
  }
}
