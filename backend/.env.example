# ── Server ──────────────────────────────────────────────
PORT=8000
NODE_ENV=production
MONGO_URI=mongodb://127.0.0.1:27017/indiamart

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=change_this_to_random_secret
JWT_ACCESS_EXPIRY=1d
JWT_REFRESH_SECRET=another_random_secret
JWT_REFRESH_EXPIRY=7d
CLIENT_URL=http://localhost:3000

# ── MSG91 (Primary SMS) ──────────────────────────────────
# Get: https://msg91.com → Dashboard → API Keys
MSG91_AUTH_KEY=YOUR_MSG91_AUTH_KEY
MSG91_TEMPLATE_ID=YOUR_MSG91_TEMPLATE_ID

# ── Fast2SMS (Fallback SMS) ──────────────────────────────
# Get: https://fast2sms.com → Dev API
FAST2SMS_API_KEY=YOUR_FAST2SMS_API_KEY

# ── Payments ─────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
